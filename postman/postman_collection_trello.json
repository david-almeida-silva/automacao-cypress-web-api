  "item": [
    {
      "name": "Buscar Action e Validar 'name'",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Validar o status code da resposta do serviço",
              "pm.test(\"Status code é 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// 2. Exibir o conteúdo do campo 'name' da estrutura 'list'",
              "pm.test(\"Encontrar e exibir o 'name' da 'list'\", function () {",
              "    var jsonData = pm.response.json();",
              "    ",
              "    // O Trello retorna o 'name' dentro de data -> list -> name",
              "    var nomeDaLista = jsonData.data.list.name;",
              "    ",
              "    console.log(\"--- RESULTADO DO DESAFIO ---\");",
              "    console.log(\"O conteúdo do campo 'name' da estrutura 'list' é: \" + nomeDaLista);",
              "    ",
              "    // Validação extra para garantir que o campo existe e não está vazio",
              "    pm.expect(nomeDaLista).to.be.a('string').and.not.be.empty;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.trello.com/1/actions/592f11060f95a3d3d46a987a",
          "protocol": "https",
          "host": [
            "api",
            "trello",
            "com"
          ],
          "path": [
            "1",
            "actions",
            "592f11060f95a3d3d46a987a"
          ]
        }
      },
      "response": []
    }
  ]
